# 抖音 cookie（可选，某些视频需要登录态）
DOUYIN_COOKIE=

# DeepSeek API Key（从 https://platform.deepseek.com/ 获取）
DEEPSEEK_API_KEY=

# 阿里云百炼 API Key（Paraformer-v2 语音识别，每月 10h 免费）
# 从 https://bailian.console.aliyun.com/ 获取
BAILIAN_API_KEY=

# 服务端配置
JWT_SECRET=请改成强随机字符串

# 服务器部署必填：数据与代码分离，代码目录可随意更新/重建而不丢数据
# 本地开发可不设置（默认落在项目目录内）
# DB_PATH=/data/douyin-agent/app.db
# OUTPUT_BASE_DIR=/data/douyin-agent/output
